# === PAGBANK / PAGSEGURO ===
PAGBANK_TOKEN=
PAGBANK_ENV=sandbox
PAGBANK_WEBHOOK_SECRET=

# Front-end (tokenização de cartão)
NEXT_PUBLIC_PAGBANK_PUBLIC_KEY=

# === MERCADO PAGO ===
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# Front-end
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# === STONE / PAGAR.ME ===
PAGARME_SECRET_KEY=
PAGARME_PUBLIC_KEY=
PAGARME_WEBHOOK_SECRET=

# Front-end
NEXT_PUBLIC_PAGARME_PUBLIC_KEY=

# === WEBHOOK SECRET GENÉRICO ===
